// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────

enum AccountAuditAction {
  ACCOUNT_CREATED
  CREDENTIALS_ISSUED
  CREDENTIALS_REISSUED
  PASSWORD_RESET
  PASSWORD_CHANGED
  FORCE_PASSWORD_CHANGE
  ACCOUNT_ACTIVATED
  ACCOUNT_SUSPENDED
  ACCOUNT_DISABLED
  ACCOUNT_UNLOCKED
  ACCOUNT_DELETED
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ARCHIVED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EmploymentStatus {
  PERMANENT
  CONTRACT
  PROBATION
  RESIGNED
  TERMINATED
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  TRANSFERRED
  GRADUATED
  EXPELLED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum NoticePriority {
  LOW
  MEDIUM
  HIGH
}

enum TeacherDesignation {
  PRINCIPAL
  VICE_PRINCIPAL
  COORDINATOR
  SENIOR_TEACHER
  TEACHER
  ASSISTANT_TEACHER
}

// ─── Finance Enums ────────────────────────────────────────────

enum FeeCategory {
  STANDARD
  SIBLING
}

enum FeeRecordStatus {
  PENDING
  PAID
  PARTIAL
  WAIVED
  OVERDUE
}

enum PaymentMode {
  CASH
  BANK_TRANSFER
  CHEQUE
  ONLINE
}

// ─── User ─────────────────────────────────────────────────────
// Holds authentication credentials only.
// Profile data lives in separate child models (Milestone 3).

model User {
  id                  String        @id @default(uuid()) @db.Uuid
  username            String        @unique
  email               String        @unique
  passwordHash        String        @map("password_hash")
  role                Role
  accountStatus       AccountStatus @default(ACTIVE) @map("account_status")
  mustChangePassword  Boolean       @default(true) @map("must_change_password")
  refreshTokenVersion Int           @default(0) @map("refresh_token_version")
  failedLoginAttempts Int           @default(0) @map("failed_login_attempts")
  lastFailedLoginAt   DateTime?     @map("last_failed_login_at")
  lockedUntil         DateTime?     @map("locked_until")
  lastLoginAt         DateTime?     @map("last_login_at")
  passwordChangedAt   DateTime?     @map("password_changed_at")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  teacher          Teacher?
  student          Student?
  notices          Notice[]
  accountAuditLogs AccountAuditLog[] @relation("AuditSubject")
  actionsPerformed AccountAuditLog[] @relation("AuditActor")

  @@index([role])
  @@index([accountStatus])
  @@map("users")
}

// ─── Academic Session ─────────────────────────────────────────
// Represents an academic year (e.g. "2024-2025").
// Only one session can be active at a time.

model AcademicSession {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  students           Student[]
  timetables         Timetable[]
  feePlans           FeePlan[]
  feeRecords         FeeRecord[]
  teacherAssignments TeacherAssignment[]
  announcements      Announcement[]
  exams              Exam[]
  admitCards         AdmitCard[]
  periodMasters      PeriodMaster[]

  @@index([isActive])
  @@map("academic_sessions")
}

// ─── Class ────────────────────────────────────────────────────
// Represents a grade or class level (e.g. "Grade 10", "Class X").

model Class {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sections           Section[]
  classSubjects      ClassSubject[]
  teacherAssignments TeacherAssignment[]
  students           Student[]
  timetables         Timetable[]
  feePlans           FeePlan[]
  feeRecords         FeeRecord[]
  announcements      Announcement[]

  @@index([isActive])
  @@index([displayOrder])
  @@map("classes")
}

// ─── Section ──────────────────────────────────────────────────
// Represents a division within a class (e.g. "A", "B", "C").

model Section {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  capacity  Int      @default(40)
  isActive  Boolean  @default(true) @map("is_active")
  classId   String   @map("class_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  class              Class               @relation(fields: [classId], references: [id])
  teacherAssignments TeacherAssignment[]
  students           Student[]
  timetables         Timetable[]
  attendance         Attendance[]
  announcements      Announcement[]

  @@unique([classId, name])
  @@index([classId])
  @@index([isActive])
  @@map("sections")
}

// ─── Subject ──────────────────────────────────────────────────
// Represents a subject taught at the school (e.g. "Mathematics", "MATH101").

model Subject {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  classSubjects      ClassSubject[]
  teacherAssignments TeacherAssignment[]
  timetables         Timetable[]

  @@index([isActive])
  @@map("subjects")
}

// ─── Class–Subject Assignment ─────────────────────────────────
// Many-to-many: which subjects are taught in which class.

model ClassSubject {
  classId   String @map("class_id") @db.Uuid
  subjectId String @map("subject_id") @db.Uuid

  class   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@id([classId, subjectId])
  @@map("class_subjects")
}

// ─── Teacher ──────────────────────────────────────────────────
// Teacher profile. Linked optionally to a User account for login.

model Teacher {
  id               String              @id @default(uuid()) @db.Uuid
  userId           String?             @unique @map("user_id") @db.Uuid
  employeeId       String              @unique @map("employee_id")
  firstName        String              @map("first_name")
  lastName         String              @map("last_name")
  gender           Gender
  dateOfBirth      DateTime?           @map("date_of_birth") @db.Date
  phone            String?
  email            String              @unique
  qualification    String?
  experienceYears  Int                 @default(0) @map("experience_years")
  department       String?
  designation      TeacherDesignation? @default(TEACHER) @map("designation")
  // NOTE: designation will be consumed by Leave Module, Payroll, Dashboard, Permissions.
  joiningDate      DateTime            @map("joining_date") @db.Date
  employmentStatus EmploymentStatus    @default(PERMANENT) @map("employment_status")
  address          String?
  bloodGroup       BloodGroup?         @map("blood_group")
  emergencyContact String?             @map("emergency_contact")
  emergencyPhone   String?             @map("emergency_phone")
  photoUrl         String?             @map("photo_url")
  // NOTE (photoUrl): URL-only in this milestone. Future Storage Module will add file upload
  // while reusing this same column — no schema migration required at that point.
  notes            String?
  isActive         Boolean             @default(true) @map("is_active")
  deletedAt        DateTime?           @map("deleted_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  user          User?               @relation(fields: [userId], references: [id])
  assignments   TeacherAssignment[]
  timetables    Timetable[]
  announcements Announcement[]

  @@index([isActive])
  @@index([employmentStatus])
  @@index([designation])
  @@index([deletedAt])
  @@map("teachers")
}

// ─── Teacher Assignment ───────────────────────────────────────
// Maps a teacher to a class + section + subject combination.

model TeacherAssignment {
  id             String  @id @default(uuid()) @db.Uuid
  teacherId      String  @map("teacher_id") @db.Uuid
  sessionId      String  @map("session_id") @db.Uuid
  classId        String  @map("class_id") @db.Uuid
  sectionId      String  @map("section_id") @db.Uuid
  subjectId      String  @map("subject_id") @db.Uuid
  isClassTeacher Boolean @default(false) @map("is_class_teacher")

  teacher Teacher         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  session AcademicSession @relation(fields: [sessionId], references: [id])
  class   Class           @relation(fields: [classId], references: [id])
  section Section         @relation(fields: [sectionId], references: [id])
  subject Subject         @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, sessionId, classId, sectionId, subjectId])
  @@index([teacherId])
  @@index([sessionId])
  @@index([classId])
  @@index([isClassTeacher])
  @@map("teacher_assignments")
}

// ─── Student ──────────────────────────────────────────────────
// Student profile. Linked optionally to a User account for login.

model Student {
  id              String      @id @default(uuid()) @db.Uuid
  userId          String?     @unique @map("user_id") @db.Uuid
  admissionNumber String      @unique @map("admission_number")
  rollNumber      String?     @map("roll_number")
  firstName       String      @map("first_name")
  lastName        String      @map("last_name")
  gender          Gender
  dateOfBirth     DateTime?   @map("date_of_birth") @db.Date
  bloodGroup      BloodGroup? @map("blood_group")
  phone           String?
  email           String?
  photoUrl        String?     @map("photo_url")

  // Parent Information
  fatherName  String? @map("father_name")
  fatherPhone String? @map("father_phone")
  motherName  String? @map("mother_name")
  motherPhone String? @map("mother_phone")

  // Guardian Information
  guardianName     String? @map("guardian_name")
  guardianPhone    String? @map("guardian_phone")
  guardianRelation String? @map("guardian_relation")

  // Emergency Contact
  emergencyContact String? @map("emergency_contact")
  emergencyPhone   String? @map("emergency_phone")

  address String?

  // Academic Assignment
  sessionId String? @map("session_id") @db.Uuid
  classId   String? @map("class_id") @db.Uuid
  sectionId String? @map("section_id") @db.Uuid

  // Fee Assignment (Milestone 5)
  feeCategory      FeeCategory? @default(STANDARD) @map("fee_category")
  feePlanId        String?      @map("fee_plan_id") @db.Uuid
  siblingStudentId String?      @map("sibling_student_id") @db.Uuid
  siblingFeeAmount Int?         @map("sibling_fee_amount")

  admissionDate DateTime      @map("admission_date") @db.Date
  status        StudentStatus @default(ACTIVE)
  notes         String?

  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user    User?            @relation(fields: [userId], references: [id])
  session AcademicSession? @relation(fields: [sessionId], references: [id])
  class   Class?           @relation(fields: [classId], references: [id])
  section Section?         @relation(fields: [sectionId], references: [id])

  // Fee relations (Milestone 5)
  feePlan   FeePlan?  @relation(fields: [feePlanId], references: [id])
  sibling   Student?  @relation("SiblingRelation", fields: [siblingStudentId], references: [id])
  siblingOf Student[] @relation("SiblingRelation")

  attendanceRecords AttendanceRecord[]
  feeRecords        FeeRecord[]
  admitCards        AdmitCard[]
  reportCards       ReportCard[]

  @@index([isActive])
  @@index([status])
  @@index([deletedAt])
  @@index([sessionId])
  @@index([classId])
  @@index([sectionId])
  @@index([feePlanId])
  @@map("students")
}

// ─── Timetable ────────────────────────────────────────────────
// Defines the weekly class schedule: which teacher teaches which
// subject in which section at which period/time slot.

model Timetable {
  id           String    @id @default(uuid()) @db.Uuid
  sessionId    String    @map("session_id") @db.Uuid
  classId      String    @map("class_id") @db.Uuid
  sectionId    String    @map("section_id") @db.Uuid
  teacherId    String    @map("teacher_id") @db.Uuid
  subjectId    String    @map("subject_id") @db.Uuid
  dayOfWeek    DayOfWeek @map("day_of_week")
  periodNumber Int       @map("period_number")
  room         String?

  // For substitute/override logic
  isOverride   Boolean   @default(false) @map("is_override")
  overrideDate DateTime? @map("override_date") @db.Date

  // Audit fields — plain UUIDs, populated from req.user.sub
  createdById String? @map("created_by_id") @db.Uuid
  updatedById String? @map("updated_by_id") @db.Uuid

  // Soft delete
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  session AcademicSession @relation(fields: [sessionId], references: [id])
  class   Class           @relation(fields: [classId], references: [id])
  section Section         @relation(fields: [sectionId], references: [id])
  teacher Teacher         @relation(fields: [teacherId], references: [id])
  subject Subject         @relation(fields: [subjectId], references: [id])

  // DB-level double-booking prevention
  @@unique([sectionId, dayOfWeek, periodNumber]) // one subject per section slot
  @@unique([teacherId, dayOfWeek, periodNumber]) // teacher can't be in two places
  @@index([sessionId])
  @@index([sectionId])
  @@index([teacherId])
  @@index([deletedAt])
  @@map("timetables")
}

model PeriodMaster {
  id           String    @id @default(uuid()) @db.Uuid
  sessionId    String    @map("session_id") @db.Uuid
  periodNumber Int       @map("period_number")
  startTime    String    @map("start_time") // "HH:MM" 24-hour format
  endTime      String    @map("end_time") // "HH:MM" 24-hour format

  session AcademicSession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, periodNumber])
  @@map("period_master")
}

// ─── Notices & Announcements ───────────────────────────────────────────────

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

model Attendance {
  id           String   @id @default(uuid()) @db.Uuid
  date         DateTime @db.Date
  sectionId    String   @map("section_id") @db.Uuid
  recordedById String   @map("recorded_by_id") @db.Uuid

  // Audit
  createdById String? @map("created_by_id") @db.Uuid
  updatedById String? @map("updated_by_id") @db.Uuid

  // Soft delete
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  section Section            @relation(fields: [sectionId], references: [id])
  records AttendanceRecord[]

  // One attendance sheet per section per day
  @@unique([sectionId, date])
  @@index([date])
  @@index([sectionId])
  @@index([isDeleted])
  @@map("attendance")
}

// ─── Attendance Record ────────────────────────────────────────
// Child: one row per student in the attendance sheet.

model AttendanceRecord {
  id           String           @id @default(uuid()) @db.Uuid
  attendanceId String           @map("attendance_id") @db.Uuid
  studentId    String           @map("student_id") @db.Uuid
  status       AttendanceStatus
  remarks      String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id])

  // One record per student per attendance sheet
  @@unique([attendanceId, studentId])
  @@index([attendanceId])
  @@index([studentId])
  @@map("attendance_records")
}

// ─── Noticeboard ──────────────────────────────────────────────

model Notice {
  id             String         @id @default(uuid()) @db.Uuid
  title          String
  content        String         @db.Text
  priority       NoticePriority @default(MEDIUM)
  targetRoles    Role[] // Empty array means visible to all
  targetClassIds String[]       @map("target_class_ids") @db.Uuid // Empty means all classes (if applicable)

  publishedAt DateTime  @default(now()) @map("published_at")
  expiresAt   DateTime? @map("expires_at")

  authorId String @map("author_id") @db.Uuid
  author   User   @relation(fields: [authorId], references: [id])

  attachments String[] // URLs for attached files

  // Audit
  createdById String? @map("created_by_id") @db.Uuid
  updatedById String? @map("updated_by_id") @db.Uuid

  // Soft delete
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([publishedAt])
  @@index([expiresAt])
  @@index([isDeleted])
  @@map("notices")
}

// ─── Username Sequence ────────────────────────────────────────

model UsernameSequence {
  prefix  String @id
  lastSeq Int    @default(0) @map("last_seq")

  @@map("username_sequences")
}

// ─── Account Audit Log ────────────────────────────────────────

model AccountAuditLog {
  id          String             @id @default(uuid()) @db.Uuid
  userId      String             @map("user_id") @db.Uuid
  performedBy String?            @map("performed_by") @db.Uuid
  action      AccountAuditAction
  remarks     String?
  ipAddress   String?            @map("ip_address")
  userAgent   String?            @map("user_agent")
  createdAt   DateTime           @default(now()) @map("created_at")

  user  User  @relation("AuditSubject", fields: [userId], references: [id])
  actor User? @relation("AuditActor", fields: [performedBy], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("account_audit_logs")
}

// ─── Fee Plan ─────────────────────────────────────────────────
// Defines a fee structure for a class in an academic session.
// Extensible via FeePlanType enum — new plan types added without schema redesign.
// All monetary values stored in paise (1 INR = 100 paise).

model FeePlan {
  id            String          @id @default(uuid()) @db.Uuid
  name          String
  sessionId     String          @map("session_id") @db.Uuid
  classId       String          @map("class_id") @db.Uuid
  monthlyAmount Int             @map("monthly_amount") // paise (e.g. 150000 = Rs 1500)
  description   String?
  isActive        Boolean     @default(true) @map("is_active")

  // Audit
  createdById String? @map("created_by_id") @db.Uuid
  updatedById String? @map("updated_by_id") @db.Uuid

  // Soft delete
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  session    AcademicSession @relation(fields: [sessionId], references: [id])
  class      Class           @relation(fields: [classId], references: [id])
  students   Student[]
  feeRecords FeeRecord[]

  @@unique([name, sessionId, classId])
  @@index([sessionId])
  @@index([classId])
  @@index([isActive])
  @@index([isDeleted])
  @@map("fee_plans")
}

// ─── Fee Record ───────────────────────────────────────────────
// Monthly fee record per student. One record per student per month per session.
// Created on-demand by admin (future: auto-generated by cron job).
// All monetary values stored in paise.

model FeeRecord {
  id        String @id @default(uuid()) @db.Uuid
  studentId String  @map("student_id") @db.Uuid
  feePlanId String? @map("fee_plan_id") @db.Uuid
  sessionId String  @map("session_id") @db.Uuid
  classId   String @map("class_id") @db.Uuid

  // Month identifier
  month Int // 1-12
  year  Int // e.g. 2025

  // Financial fields (all in paise)
  monthlyAmount  Int             @map("monthly_amount") // base amount from fee plan or sibling fee
  lateFine       Int             @default(0) @map("late_fine") // future: applied by cron
  netAmount      Int             @map("net_amount") // monthlyAmount + lateFine
  paidAmount     Int             @default(0) @map("paid_amount") // amount paid so far
  balanceAmount  Int             @map("balance_amount") // netAmount - paidAmount
  status         FeeRecordStatus @default(PENDING)
  dueDate        DateTime?       @map("due_date") @db.Date // future: configurable

  // Latest payment snapshot (full history in FeePayment table)
  lastPaymentDate DateTime?    @map("last_payment_date") @db.Date
  lastPaymentMode PaymentMode? @map("last_payment_mode")
  receiptNumber   String?      @map("receipt_number") // future: auto-generated

  remarks String?

  // Audit
  createdById String? @map("created_by_id") @db.Uuid
  updatedById String? @map("updated_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student  Student         @relation(fields: [studentId], references: [id])
  feePlan  FeePlan?        @relation(fields: [feePlanId], references: [id])
  session  AcademicSession @relation(fields: [sessionId], references: [id])
  class    Class           @relation(fields: [classId], references: [id])
  payments FeePayment[] // Full payment history (future)

  @@unique([studentId, month, year, sessionId])
  @@index([studentId])
  @@index([sessionId])
  @@index([classId])
  @@index([status])
  @@index([month, year])
  @@map("fee_records")
}

// ─── Fee Payment ──────────────────────────────────────────────
// Individual payment transactions against a fee record.
// Schema designed now; routes/UI implemented in a future milestone.
// Supports partial payments and full payment history.

model FeePayment {
  id             String      @id @default(uuid()) @db.Uuid
  feeRecordId    String      @map("fee_record_id") @db.Uuid
  amount         Int // paise
  paymentDate    DateTime    @map("payment_date") @db.Date
  paymentMode    PaymentMode @map("payment_mode")
  receiptNumber  String?     @map("receipt_number")
  transactionRef String?     @map("transaction_ref") // bank/gateway ref
  remarks        String?

  // Audit
  collectedById String?  @map("collected_by_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  feeRecord FeeRecord @relation(fields: [feeRecordId], references: [id])

  @@index([feeRecordId])
  @@index([paymentDate])
  @@map("fee_payments")
}

// ─── Fee Reminder Rule ────────────────────────────────────────
// Configuration for automated fee reminder notifications.
// Schema designed now; cron job + notifications implemented in a future milestone.

model FeeReminderRule {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  name       String
  daysOffset Int      @map("days_offset") // negative=before due date, 0=on due date, positive=after
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("fee_reminder_rules")
}

// ─── Announcements (Teacher to Section) ───────────────────────

model Announcement {
  id          String    @id @default(uuid()) @db.Uuid
  title       String
  content     String    @db.Text
  isPinned    Boolean   @default(false) @map("is_pinned")
  expiresAt   DateTime? @map("expires_at")
  attachments String[]  @default([])

  // Assignment scope
  sessionId String @map("session_id") @db.Uuid
  classId   String @map("class_id") @db.Uuid
  sectionId String @map("section_id") @db.Uuid

  authorId String @map("author_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  session AcademicSession @relation(fields: [sessionId], references: [id])
  class   Class           @relation(fields: [classId], references: [id])
  section Section         @relation(fields: [sectionId], references: [id])
  author  Teacher         @relation(fields: [authorId], references: [id])

  @@index([sessionId])
  @@index([classId])
  @@index([sectionId])
  @@index([authorId])
  @@map("announcements")
}

// ─── Exams (Admin/Global setup for Report Cards) ──────────────

model Exam {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  name      String
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  reportCards ReportCard[]

  @@unique([sessionId, name])
  @@index([sessionId])
  @@map("exams")
}

// ─── Admit Cards ──────────────────────────────────────────────

model AdmitCard {
  id        String @id @default(uuid()) @db.Uuid
  sessionId String @map("session_id") @db.Uuid
  studentId String @map("student_id") @db.Uuid
  fileUrl   String @map("file_url")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  session AcademicSession @relation(fields: [sessionId], references: [id])
  student Student         @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@map("admit_cards")
}

// ─── Report Cards ─────────────────────────────────────────────

model ReportCard {
  id        String @id @default(uuid()) @db.Uuid
  examId    String @map("exam_id") @db.Uuid
  studentId String @map("student_id") @db.Uuid
  fileUrl   String @map("file_url")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  exam    Exam    @relation(fields: [examId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
  @@map("report_cards")
}

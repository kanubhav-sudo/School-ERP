// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ARCHIVED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EmploymentStatus {
  PERMANENT
  CONTRACT
  PROBATION
  RESIGNED
  TERMINATED
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  TRANSFERRED
  GRADUATED
  EXPELLED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

// ─── User ─────────────────────────────────────────────────────
// Holds authentication credentials only.
// Profile data lives in separate child models (Milestone 3).

model User {
  id                   String        @id @default(uuid()) @db.Uuid
  username             String        @unique
  email                String        @unique
  passwordHash         String        @map("password_hash")
  role                 Role
  accountStatus        AccountStatus @default(ACTIVE) @map("account_status")
  isTemporaryPassword  Boolean       @default(true) @map("is_temporary_password")
  refreshTokenVersion  Int           @default(0) @map("refresh_token_version")
  lastLoginAt          DateTime?     @map("last_login_at")
  passwordChangedAt    DateTime?     @map("password_changed_at")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  teacher Teacher?
  student Student?

  @@index([role])
  @@index([accountStatus])
  @@map("users")
}

// ─── Academic Session ─────────────────────────────────────────
// Represents an academic year (e.g. "2024-2025").
// Only one session can be active at a time.

model AcademicSession {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  students   Student[]
  timetables Timetable[]

  @@index([isActive])
  @@map("academic_sessions")
}

// ─── Class ────────────────────────────────────────────────────
// Represents a grade or class level (e.g. "Grade 10", "Class X").

model Class {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    @unique
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  sections           Section[]
  classSubjects      ClassSubject[]
  teacherAssignments TeacherAssignment[]
  students           Student[]
  timetables         Timetable[]

  @@index([isActive])
  @@index([displayOrder])
  @@map("classes")
}

// ─── Section ──────────────────────────────────────────────────
// Represents a division within a class (e.g. "A", "B", "C").

model Section {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  capacity  Int      @default(40)
  isActive  Boolean  @default(true) @map("is_active")
  classId   String   @map("class_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  class              Class              @relation(fields: [classId], references: [id])
  teacherAssignments TeacherAssignment[]
  students           Student[]
  timetables         Timetable[]
  attendance         Attendance[]

  @@unique([classId, name])
  @@index([classId])
  @@index([isActive])
  @@map("sections")
}

// ─── Subject ──────────────────────────────────────────────────
// Represents a subject taught at the school (e.g. "Mathematics", "MATH101").

model Subject {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  code        String       @unique
  description String?
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  classSubjects      ClassSubject[]
  teacherAssignments TeacherAssignment[]
  timetables         Timetable[]

  @@index([isActive])
  @@map("subjects")
}

// ─── Class–Subject Assignment ─────────────────────────────────
// Many-to-many: which subjects are taught in which class.

model ClassSubject {
  classId   String  @map("class_id") @db.Uuid
  subjectId String  @map("subject_id") @db.Uuid

  class   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@id([classId, subjectId])
  @@map("class_subjects")
}

// ─── Teacher ──────────────────────────────────────────────────
// Teacher profile. Linked optionally to a User account for login.

model Teacher {
  id               String           @id @default(uuid()) @db.Uuid
  userId           String?          @unique @map("user_id") @db.Uuid
  employeeId       String           @unique @map("employee_id")
  firstName        String           @map("first_name")
  lastName         String           @map("last_name")
  gender           Gender
  dateOfBirth      DateTime?        @map("date_of_birth") @db.Date
  phone            String?
  email            String           @unique
  qualification    String?
  experienceYears  Int              @default(0) @map("experience_years")
  department       String?
  joiningDate      DateTime         @map("joining_date") @db.Date
  employmentStatus EmploymentStatus @default(PERMANENT) @map("employment_status")
  address          String?
  notes            String?
  isActive         Boolean          @default(true) @map("is_active")
  deletedAt        DateTime?        @map("deleted_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  user        User?               @relation(fields: [userId], references: [id])
  assignments TeacherAssignment[]
  timetables  Timetable[]

  @@index([isActive])
  @@index([employmentStatus])
  @@index([deletedAt])
  @@map("teachers")
}

// ─── Teacher Assignment ───────────────────────────────────────
// Maps a teacher to a class + section + subject combination.

model TeacherAssignment {
  id        String @id @default(uuid()) @db.Uuid
  teacherId String @map("teacher_id") @db.Uuid
  classId   String @map("class_id") @db.Uuid
  sectionId String @map("section_id") @db.Uuid
  subjectId String @map("subject_id") @db.Uuid

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, classId, sectionId, subjectId])
  @@index([teacherId])
  @@index([classId])
  @@map("teacher_assignments")
}

// ─── Student ──────────────────────────────────────────────────
// Student profile. Linked optionally to a User account for login.

model Student {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String?       @unique @map("user_id") @db.Uuid
  admissionNumber  String        @unique @map("admission_number")
  rollNumber       String?       @map("roll_number")
  firstName        String        @map("first_name")
  lastName         String        @map("last_name")
  gender           Gender
  dateOfBirth      DateTime?     @map("date_of_birth") @db.Date
  bloodGroup       BloodGroup?   @map("blood_group")
  phone            String?
  email            String?
  photoUrl         String?       @map("photo_url")

  // Parent Information
  fatherName       String?       @map("father_name")
  fatherPhone      String?       @map("father_phone")
  motherName       String?       @map("mother_name")
  motherPhone      String?       @map("mother_phone")

  // Guardian Information
  guardianName     String?       @map("guardian_name")
  guardianPhone    String?       @map("guardian_phone")
  guardianRelation String?       @map("guardian_relation")

  // Emergency Contact
  emergencyContact String?       @map("emergency_contact")
  emergencyPhone   String?       @map("emergency_phone")

  address          String?

  // Academic Assignment
  sessionId        String?       @map("session_id") @db.Uuid
  classId          String?       @map("class_id") @db.Uuid
  sectionId        String?       @map("section_id") @db.Uuid

  admissionDate    DateTime      @map("admission_date") @db.Date
  status           StudentStatus @default(ACTIVE)
  notes            String?

  isActive         Boolean       @default(true) @map("is_active")
  deletedAt        DateTime?     @map("deleted_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  user    User?            @relation(fields: [userId], references: [id])
  session AcademicSession? @relation(fields: [sessionId], references: [id])
  class   Class?           @relation(fields: [classId], references: [id])
  section Section?         @relation(fields: [sectionId], references: [id])

  attendanceRecords AttendanceRecord[]

  @@index([isActive])
  @@index([status])
  @@index([deletedAt])
  @@index([sessionId])
  @@index([classId])
  @@index([sectionId])
  @@map("students")
}

// ─── Timetable ────────────────────────────────────────────────
// Defines the weekly class schedule: which teacher teaches which
// subject in which section at which period/time slot.

model Timetable {
  id           String    @id @default(uuid()) @db.Uuid
  sessionId    String    @map("session_id") @db.Uuid
  classId      String    @map("class_id") @db.Uuid
  sectionId    String    @map("section_id") @db.Uuid
  teacherId    String    @map("teacher_id") @db.Uuid
  subjectId    String    @map("subject_id") @db.Uuid
  dayOfWeek    DayOfWeek @map("day_of_week")
  periodNumber Int       @map("period_number")
  startTime    String    @map("start_time")  // "HH:MM" 24-hour format
  endTime      String    @map("end_time")    // "HH:MM" 24-hour format
  room         String?

  // Audit fields — plain UUIDs, populated from req.user.sub
  createdById  String?   @map("created_by_id") @db.Uuid
  updatedById  String?   @map("updated_by_id") @db.Uuid

  // Soft delete
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at")
  deletedById  String?   @map("deleted_by_id") @db.Uuid

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  session  AcademicSession @relation(fields: [sessionId], references: [id])
  class    Class           @relation(fields: [classId], references: [id])
  section  Section         @relation(fields: [sectionId], references: [id])
  teacher  Teacher         @relation(fields: [teacherId], references: [id])
  subject  Subject         @relation(fields: [subjectId], references: [id])

  // DB-level double-booking prevention
  @@unique([sectionId, dayOfWeek, periodNumber])  // one subject per section slot
  @@unique([teacherId, dayOfWeek, periodNumber])  // teacher can't be in two places

  @@index([sessionId])
  @@index([sectionId])
  @@index([teacherId])
  @@index([isDeleted])
  @@map("timetables")
}

// ─── Attendance ───────────────────────────────────────────────
// Parent: one attendance sheet per section per day.
// Soft-delete on parent cascades logically (records are also preserved).

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

model Attendance {
  id           String    @id @default(uuid()) @db.Uuid
  date         DateTime  @db.Date
  sectionId    String    @map("section_id") @db.Uuid
  recordedById String    @map("recorded_by_id") @db.Uuid

  // Audit
  createdById  String?   @map("created_by_id") @db.Uuid
  updatedById  String?   @map("updated_by_id") @db.Uuid

  // Soft delete
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at")
  deletedById  String?   @map("deleted_by_id") @db.Uuid

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  section  Section            @relation(fields: [sectionId], references: [id])
  records  AttendanceRecord[]

  // One attendance sheet per section per day
  @@unique([sectionId, date])
  @@index([date])
  @@index([sectionId])
  @@index([isDeleted])
  @@map("attendance")
}

// ─── Attendance Record ────────────────────────────────────────
// Child: one row per student in the attendance sheet.

model AttendanceRecord {
  id           String           @id @default(uuid()) @db.Uuid
  attendanceId String           @map("attendance_id") @db.Uuid
  studentId    String           @map("student_id") @db.Uuid
  status       AttendanceStatus
  remarks      String?

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id])

  // One record per student per attendance sheet
  @@unique([attendanceId, studentId])
  @@index([attendanceId])
  @@index([studentId])
  @@map("attendance_records")
}
